# EdgeDeploy Environment Variables
# Copy to .env and fill in values

# AWS Configuration
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# S3 Storage
S3_BUCKET_NAME=edgedeploy-models
S3_MODEL_PREFIX=models/

# SageMaker
SAGEMAKER_EXECUTION_ROLE=arn:aws:iam::ACCOUNT:role/SageMakerRole
SAGEMAKER_ENDPOINT_NAME=edgedeploy-endpoint

# MLflow Tracking (optional)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=edgedeploy

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/edgedeploy.log

# Application
APP_ENV=development
DEBUG=false
SEED=42

# Drift Detection
DRIFT_ALERT_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ
DRIFT_CHECK_INTERVAL_MINUTES=60

# Deployment
DEPLOYMENT_ROLLBACK_ENABLED=true
DEPLOYMENT_HEALTH_CHECK_INTERVAL_SECONDS=30


